{
  "name": "person-intelligence-search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Person Intelligence Search Platform - source-available person-centric knowledge base and hybrid search",
  "license": "AGPL-3.0-only",
  "scripts": {
    "start": "node apps/api/server.ts",
    "dev": "node --watch apps/api/server.ts",
    "worker": "node apps/worker/server.ts",
    "migrate": "node scripts/migrate.ts",
    "seed": "node scripts/seed-demo.ts",
    "reembed": "node scripts/reembed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "npm run typecheck && npm run lint && npm run test",
    "test": "vitest run",
    "smoke": "node scripts/smoke-test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@electric-sql/pglite": "^0.4.6",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.18.0",
    "@types/pg": "^8.15.6",
    "typescript": "^5.9.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.18"
  }
}
