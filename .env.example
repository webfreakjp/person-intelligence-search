# ============================================================
# 必須: LLM / embedding プロバイダ設定
# 自然文検索の解析・人物/文脈/フィールド抽出・要約・ベクトル検索に使用します。
# モデル名にデフォルトはありません。利用したいモデルを明示してください
# （プロバイダのモデル一覧から、embedding用と汎用LLM用を1つずつ）。
# ============================================================
OPENAI_API_KEY=
EMBEDDING_MODEL=
LLM_MODEL=

# ベクトル次元。初回マイグレーション時にDBへ固定されます（後から変える場合は
# DB再構築 + `npm run reembed` が必要）。指定モデルが対応する次元にしてください。
EMBEDDING_DIMENSION=256

# LLMだけ別プロバイダ/別キーを使う場合（任意）
# LLM_PROVIDER=openai            # openai | anthropic（既定: openai。ANTHROPIC_API_KEYのみ設定時はanthropic）
# ANTHROPIC_API_KEY=
# LLM_API_KEY=                   # OPENAI_API_KEY等と別のキーを使う場合のみ
# LLM_BASE_URL=                  # OpenAI互換エンドポイントを使う場合
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=

# --- server ---
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
# /v1 を保護する場合に設定（X-API-Key または Bearer トークンで送信）
API_KEY=

# --- storage ---
# pglite  : 組み込みPostgreSQL（依存ゼロ・単一プロセス、開発/デモ用）
# postgres: 外部PostgreSQL + pgvector（本番。docker-compose.yml 参照）
STORE_PROVIDER=pglite
DATABASE_URL=postgres://persondb:persondb@localhost:5432/persondb
# PGLITE_DATA_DIR=./data/pglite
PGROONGA_ENABLED=true

# --- tenancy / language ---
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_LANGUAGE=ja

# --- worker ---
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL_MS=1000
JOB_MAX_ATTEMPTS=3
# INLINE_WORKER=true  # APIプロセス内でジョブを処理（pglite時の既定）

# --- entity linking / extraction policy ---
AUTO_CREATE_PERSONS=false
AUTO_APPLY_CONFIDENCE=0.8
